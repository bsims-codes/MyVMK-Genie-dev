{
  "manifest_version": 3,
  "name": "MyVMK Genie",
  "version": "1.0.0",
  "description": "Companion extension for MyVMK - quick phrases, screenshots, and more",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://play.myvmk.com/*",
    "https://*.myvmk.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://play.myvmk.com/*", "https://*.myvmk.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "phrase-1": {
      "suggested_key": { "default": "Ctrl+Alt+1" },
      "description": "Send phrase 1"
    },
    "phrase-2": {
      "suggested_key": { "default": "Ctrl+Alt+2" },
      "description": "Send phrase 2"
    },
    "phrase-3": {
      "suggested_key": { "default": "Ctrl+Alt+3" },
      "description": "Send phrase 3"
    },
    "phrase-4": {
      "suggested_key": { "default": "Ctrl+Alt+4" },
      "description": "Send phrase 4"
    },
    "phrase-5": {
      "suggested_key": { "default": "Ctrl+Alt+5" },
      "description": "Send phrase 5"
    },
    "take-screenshot": {
      "suggested_key": { "default": "Ctrl+Alt+S" },
      "description": "Take screenshot"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
